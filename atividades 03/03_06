#include <stdio.h>

int main() {
    int i, j;
    float matriz[4][4];
    float soma, media;

    // Leitura das notas
    for(i = 0; i < 4; i++) {
        printf("\nDisciplina %d\n", i + 1);

        for(j = 0; j < 4; j++) {
            printf("Digite a nota %d: ", j + 1);
            scanf("%f", &matriz[i][j]);
        }
    }

    // Cálculo e exibição das médias
    for(i = 0; i < 4; i++) {
        soma = 0;

        for(j = 0; j < 4; j++) {
            soma += matriz[i][j];
        }

        media = soma / 4;

        printf("Media da disciplina %d = %.2f\n", i + 1, media);
    }

    return 0;
}
