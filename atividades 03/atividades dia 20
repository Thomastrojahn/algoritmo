#include <stdio.h>

int main() {
    int vetor[8];
    int maior;

    // Leitura dos valores
    for (int i = 0; i < 8; i++) {
        printf("Digite o %dº numero: ", i + 1);
        scanf("%d", &vetor[i]);
    }

    // Inicializa com o primeiro elemento
    maior = vetor[0];

    // Procura o maior valor
    for (int i = 1; i < 8; i++) {
        if (vetor[i] > maior) {
            maior = vetor[i];
        }
    }

    // Exibe o resultado
    printf("Maior valor: %d\n", maior);

    return 0;
}
