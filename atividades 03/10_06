#include <stdio.h>

int main() {
    char palavra[20];
    char letra;
    int i;
    int contador = 0;

    printf("Digite uma palavra: ");
    scanf("%s", palavra);

    printf("Digite uma letra: ");
    scanf(" %c", &letra);

    for (i = 0; palavra[i] != '\0'; i++) {
        if (palavra[i] == letra) {
            contador++;
        }
    }

    printf("A letra '%c' aparece %d vez(es).\n", letra, contador);

    return 0;
}
