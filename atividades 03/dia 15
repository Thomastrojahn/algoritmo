/* ==============================================================
* Nome do programa: apresentar_a_nota.
*
* Objetivo: Fazer o programa falar se o aluno foi aprovado, em exame e reprovado.
*
* Autor: Thomas Halberstadt Trojahn.
*
* Data:15/04/2026.
* ================================================================*/ 



#include <stdio.h>
#include <conio.h>

main(){

    float nota;
	//faz o usuário digitar a sua nota.
	printf("digite a sua nota:");
	scanf("%f" ,&nota);
	
    //se a nota do aluno foi igual ou maior a 7 o sistema fala que ele foi aprovado.
	if(nota >= 7.0f){
		printf("aprovado");
	}
	//se a nota do aluno for entre 5 e 6,9 o sistema vai falar que ele esta em exame.
	else if(nota >=5.0f && nota <=6.9f ){
		printf("em exame");	
	}
	//e se a nota for abaixo de 5 o sistema vai falar que o aluno foi reprovado
	else{
		printf("reprovado");
	}
	


getch();


}
