*
*
* Autor: Thomas Halberstadt Trojahn.
*
*
* Data: 15/04/2026.
*
* ====================================================== */



#include <stdio.h>
#include <conio.h>
main (){
	
int temp;
	//perguntar ao usuario a temperatura.
	printf("digite a temperatura (em celcius):");
	scanf("%d", &temp);
	//quando e entre alguma coisa sempre colocar 2 && e colocar menor igual a e maior igual a.
	
	if(temp >=70 && temp <=80){
		printf("temperatura ideal para o mate");
	}//pra ser menor ou igual colocar <= e o numero.
	
	else if(temp <=70){
		printf("agua esta muito fria");
    }//e na parte do else nao precisa colocar nada apenas o printf e.
	
	else{
		printf("agua muito quente, vai queimar a erva");		
    }
	//nos if, else if e else sempre colocar {} para abrir e fechar.
getch();
		
}

