/* ======================================================
* Nome do programa: classificação_dos_triangulos.
*
* Objetivo: realizar o calculo de uma piramide.
*
* Autor: Thomas Halberstadt Trojahn.
*
* Data: 15/04/2026.
*
* =======================================================*/
#include <stdio.h>
#include <conio.h>

main(void){

	float a, b, c;
	//ele pede o primeiro valor e escaneia.
	printf("digite o primeiro valor:");
		scanf("%f", &a);
	//ele pede o segundo valor e escaneia.
	printf("digite o segundo valor:");
		scanf("%f", &b);
	//ele pede o terceiro valor e escaneia.
	printf("digite o terceiro valor:");	
		scanf("%f", &c);
	//ele calcula os valores e se os 3 lados forem iguais ele vai ser um equilatero.
	if(a + b > c && a + c > b && b + c > a){
		printf("ele e equilatero ");
	}
	//ele calcula os lados e se 2 lados forem iguais vai ser um isosceles.
	else if(a == b > c && a == c > b && b == c > a){
		printf("ele e isosceles");
	}
	//e se os 3 lados forem diferentes ele vai ser um escaleno.
	else{
		printf("ele e escaleno");
	}


getch();
}

